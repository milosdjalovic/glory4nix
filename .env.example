# PostgreSQL (Neon preporučeno za Vercel)
# Pooled connection — koristi aplikacija
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Direct connection — koristi Prisma migracije (Neon dashboard → Connection details)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Obavezno u produkciji — generiši: openssl rand -base64 32
JWT_SECRET="promijeni-ovu-vrijednost"

# Lozinka za Nix admin nakon seed-a
ADMIN_PASSWORD="jaka-lozinka-ovdje"

# Push obavještenja (generiši: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:tvoj@email.com"
